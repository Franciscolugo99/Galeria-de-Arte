# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
.codex-dev-server*.log

# local PHP configuration and runtime files
/api/config.php
/storage/*
!/storage/.htaccess
/public/uploads/profile/*
!/public/uploads/profile/.gitkeep
/public/uploads/works/*
!/public/uploads/works/.gitkeep

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
next-env.d.ts
/dist/
/.vinext/
/.wrangler/
/.sites-runtime/
/outputs/
/work/
/api/config.local.php
/storage/originals/
/public/uploads/works/*
!/public/uploads/works/.gitkeep
/public/uploads/profile/*
!/public/uploads/profile/.gitkeep
